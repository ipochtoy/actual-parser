# Marketing Hub — Переменные окружения
# Скопируй этот файл в .env и заполни реальные значения
# НИКОГДА не коммить .env в git!

# ============================================================
# Яндекс Метрика
# ============================================================

# Токен для счетчиков prostobox.com, pochtoy.com, garages
YANDEX_METRIKA_TOKEN=

# Токен с доступом ко ВСЕМ 6 счетчикам (включая qwixit и dzen)
YANDEX_METRIKA_TOKEN_QWIXIT=

# ============================================================
# Яндекс Директ
# ============================================================

# Prostobox (аккаунт: prostoboxmarketing) — валюта USD
YANDEX_DIRECT_TOKEN=

# Qwixit (аккаунт: qwixit) — валюта USD
YANDEX_QWIXIT_TOKEN=

# Pochtoy (аккаунт: pochtoynew) — валюта USD
YANDEX_POCHTOY_TOKEN=

# ============================================================
# Telegram
# ============================================================

# Бот для @prostoboxme
TELEGRAM_BOT_TOKEN_PROSTOBOX=

# Бот для @poaborr
TELEGRAM_BOT_TOKEN_POCHTOY=

# ============================================================
# Pochtoy CRM API
# ============================================================

POCHTOY_API_URL=
POCHTOY_API_TOKEN=
POCHTOY_STATS_FILE=scratch/data/pochtoy-stats.json

