+// Update multi-store progress
+function updateStoreProgress(storeName, current, total, status) {
+  const storeKey = storeName.toLowerCase();
+  const multiProgress = document.getElementById('multiProgress');
+  const progressBar = document.getElementById(`${storeKey}-progress-bar`);
+  const progressText = document.getElementById(`${storeKey}-progress-text`);
+  
+  if (!progressBar || !progressText) return;
+  
+  if (multiProgress) multiProgress.style.display = 'block';
+  
+  const percent = total > 0 ? Math.min((current / total) * 100, 100) : 0;
+  progressBar.style.width = `${percent}%`;
+  progressText.textContent = status || `${current}/${total}`;
+  
+  if (percent === 100 && current === total) {
+    progressBar.style.background = '#28a745';
+    progressText.style.color = '#28a745';
+  } else {
+    progressBar.style.background = '#667eea';
+    progressText.style.color = '#667eea';
+  }
+  
+  // Save to storage
+  chrome.storage.local.get(['progressState'], (result) => {
+    const progressState = result.progressState || {};
+    progressState[storeKey] = { current, total, status, percent, timestamp: Date.now() };
+    chrome.storage.local.set({ progressState });
+  });
+}
+
+// Restore progress state
+function restoreProgressState() {
+  chrome.storage.local.get(['progressState'], (result) => {
+    if (!result.progressState) return;
+    
+    const multiProgress = document.getElementById('multiProgress');
+    let hasProgress = false;
+    
+    ['ebay', 'iherb', 'amazon'].forEach(key => {
+      const state = result.progressState[key];
+      if (!state || Date.now() - state.timestamp > 600000) return;
+      
+      const bar = document.getElementById(`${key}-progress-bar`);
+      const text = document.getElementById(`${key}-progress-text`);
+      if (!bar || !text) return;
+      
+      hasProgress = true;
+      bar.style.width = `${state.percent}%`;
+      text.textContent = state.status;
+      
+      if (state.percent === 100) {
+        bar.style.background = '#28a745';
+        text.style.color = '#28a745';
+      }
+    });
+    
+    if (hasProgress && multiProgress) multiProgress.style.display = 'block';
+  });
+}
